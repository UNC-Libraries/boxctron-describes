# Application Configuration
APP_NAME=boxctron-describes
APP_VERSION=0.1.0
DEBUG=false

# Server Configuration
HOST=0.0.0.0
PORT=8000
# ROOT_PATH=/boxctron-describes  # Uncomment if behind reverse proxy at subpath

# Azure OpenAI Configuration
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Google Gemini Configuration (optional)
GOOGLE_API_KEY=your_google_api_key_here

# Anthropic Claude Configuration (optional)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# LiteLLM Configuration
LITELLM_FULL_DESC_MODEL=azure/gpt-4o
LITELLM_FULL_DESC_TEMPERATURE=0.7
LITELLM_FULL_DESC_MAX_TOKENS=1000
LITELLM_FULL_DESC_REASONING_EFFORT=low
LITELLM_NUM_RETRIES=3
LITELLM_DROP_PARAMS=true

LITELLM_ALT_TEXT_MODEL=azure/gpt-4o
LITELLM_ALT_TEXT_TEMPERATURE=0.7
LITELLM_ALT_TEXT_MAX_TOKENS=1000
LITELLM_ALT_TEXT_REASONING_EFFORT=low

LITELLM_REVIEW_MODEL=azure/gpt-4o
LITELLM_REVIEW_TEMPERATURE=0.7
LITELLM_REVIEW_MAX_TOKENS=1000
LITELLM_REVIEW_REASONING_EFFORT=low

# File Upload Configuration
MAX_UPLOAD_SIZE=10485760

# Image Processing Configuration
IMAGE_MAX_DIMENSION=1600

# Logging Configuration
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Options: default, json
LOG_FORMAT=default

# Options: console, file, both
LOG_OUTPUT=console

# Required if LOG_OUTPUT is 'file' or 'both'
# LOG_FILE_PATH=/var/log/boxctron-describes/app.log

# Log rotation settings (used when LOG_OUTPUT includes 'file')
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
